{\pard\plain\posx1655\posy6474\absw9298\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u80x\u111x\u114x \u101x\u108x\u108x\u111x \u112x\u114x\u101x\u111x\u99x\u117x\u112x\u97x\u100x\u97x\u115x \u112x\u111x\u114x \u110x\u117x\u101x\u115x\u116x\u114x\u97x \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u116x\u97x\u110x\u116x\u111x\u44x \u112x\u101x\u114x\u115x\u111x\u110x\u97x\u108x\u44x \u102x\u97x\u109x\u105x\u108x\u105x\u97x\u114x \u121x \u100x\u101x \u108x\u97x \u115x\u111x\u99x\u105x\u101x\u100x\u97x\u100x \u101x\u110x \u115x\u117x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u99x\u111x\u110x\u106x\u117x\u110x\u116x\u111x\u44x \u108x\u111x\u115x \u100x\u105x\u102x\u101x\u114x\u101x\u110x\u116x\u101x\u115x \u115x\u101x\u99x\u116x\u111x\u114x\u101x\u115x \u115x\u111x\u99x\u105x\u97x\u108x\u101x\u115x \u111x\u114x\u103x\u97x\u110x\u105x\u122x\u97x\u100x\u111x\u115x \u110x\u111x\u115x \u104x\u101x\u109x\u111x\u115x \u114x\u101x\u117x\u110x\u105x\u100x\u111x\u115x\u44x \u112x\u97x\u114x\u97x \u97x\u110x\u97x\u108x\u105x\u122x\u97x\u114x \u100x\u105x\u99x\u104x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u111x\u110x\u101x\u115x\u44x \u101x\u118x\u105x\u100x\u101x\u110x\u99x\u105x\u97x\u110x\u100x\u111x \u108x\u111x\u115x \u99x\u111x\u110x\u116x\u101x\u120x\u116x\u111x\u115x \u108x\u97x\u109x\u101x\u110x\u116x\u97x\u98x\u108x\u101x\u115x \u99x\u111x\u109x\u111x\u44x \u108x\u97x \u100x\u101x\u115x\u105x\u103x\u117x\u97x\u108x\u100x\u97x\u100x \u115x\u111x\u99x\u105x\u97x\u108x\u44x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x \u121x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u112x\u111x\u108x\u237x\u116x\u105x\u99x\u97x\u44x \u113x\u117x\u101x \u97x\u102x\u114x\u111x\u110x\u116x\u97x\u109x\u111x\u115x\u44x \u112x\u111x\u114x \u108x\u111x \u113x\u117x\u101x \u104x\u101x\u109x\u111x\u115x \u101x\u110x\u99x\u111x\u110x\u116x\u114x\u97x\u100x\u111x \u101x\u110x \u108x\u111x\u115x \u115x\u105x\u103x\u117x\u105x\u101x\u110x\u116x\u101x\u115x \u114x\u117x\u98x\u114x\u111x\u115x \u108x\u97x\u115x \u99x\u111x\u110x\u100x\u105x\u99x\u105x\u111x\u110x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u103x\u101x\u110x\u101x\u114x\u97x\u108x\u101x\u115x\u44x \u101x\u110x \u99x\u117x\u97x\u110x\u116x\u111x \u97x\u59x}\par }
{\pard\plain\posx1655\posy8172\absw9296\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u49x\u46x }{\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u83x\u97x\u108x\u97x\u114x\u105x\u111x\u115x \u121x \u86x\u101x\u110x\u116x\u97x\u106x\u97x\u115x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x\u115x\u58x }{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u84x\u97x\u110x\u116x\u111x \u108x\u97x\u115x \u105x\u110x\u115x\u116x\u105x\u116x\u117x\u99x\u105x\u111x\u110x\u101x\u115x \u112x\u250x\u98x\u108x\u105x\u99x\u97x\u115x \u99x\u111x\u109x\u111x \u108x\u97x\u115x \u112x\u114x\u105x\u118x\u97x\u100x\u97x\u115x \u109x\u97x\u110x\u116x\u105x\u101x\u110x\u101x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u115x\u97x\u108x\u97x\u114x\u105x\u111x\u115x \u112x\u111x\u114x \u100x\u101x\u98x\u97x\u106x\u111x \u100x\u101x\u108x \u109x\u237x\u110x\u105x\u109x\u111x \u101x\u115x\u116x\u97x\u98x\u108x\u101x\u99x\u105x\u100x\u111x \u112x\u111x\u114x \u108x\u97x \u108x\u101x\u103x\u105x\u115x\u108x\u97x\u116x\u117x\u114x\u97x \u97x\u99x\u116x\u117x\u97x\u108x\u46x \u77x\u225x\u115x \u100x\u101x \u108x\u97x \u109x\u105x\u116x\u97x\u100x \u100x\u101x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x \u115x\u101x \u101x\u110x\u99x\u117x\u101x\u110x\u116x\u114x\u97x \u101x\u110x \u112x\u111x\u98x\u114x\u101x\u122x\u97x \u121x \u112x\u111x\u98x\u114x\u101x\u122x\u97x \u101x\u120x\u116x\u114x\u101x\u109x\u97x\u46x \u76x\u111x\u115x \u97x\u110x\u225x\u108x\u105x\u115x\u105x\u115x \u101x\u115x\u116x\u97x\u100x\u237x\u115x\u116x\u105x\u99x\u111x\u115x \u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u105x\u110x\u100x\u105x\u99x\u97x\u110x \u113x\u117x\u101x \u101x\u108x \u99x\u111x\u115x\u116x\u101x \u100x\u101x \u108x\u97x \u99x\u97x\u110x\u97x\u115x\u116x\u97x \u