cf0\fs21\expnd0\expndtw0\kerning0 \u80x\u114x\u111x\u112x\u111x\u110x\u101x\u114x \u121x \u97x\u112x\u114x\u111x\u98x\u97x\u114x \u105x\u110x\u105x\u99x\u105x\u97x\u116x\u105x\u118x\u97x\u115x \u100x\u101x \u108x\u101x\u121x \u113x\u117x\u101x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u114x\u101x\u102x\u111x\u114x\u109x\u101x\u110x \u101x\u108x \u67x\u243x\u100x\u105x\u103x\u111x \u100x\u101x \u84x\u114x\u97x\u98x\u97x\u106x\u111x \u97x\u99x\u116x\u117x\u97x\u108x\u44x \u121x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u97x\u112x\u111x\u121x\u97x\u114x \u108x\u97x \u99x\u114x\u101x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u110x\u117x\u101x\u118x\u97x\u115x \u108x\u101x\u121x\u101x\u115x \u112x\u97x\u114x\u97x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u114x\u101x\u103x\u237x\u109x\u101x\u110x\u101x\u115x \u101x\u115x\u112x\u101x\u99x\u105x\u97x\u108x\u101x\u115x\u44x \u100x\u101x \u98x\u101x\u110x\u101x\u102x\u105x\u99x\u105x\u111x \u112x\u97x\u114x\u97x \u108x\u97x\u115x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x\u44x \u97x\u110x\u116x\u101x \u101x\u108x \u67x\u111x\u110x\u103x\u114x\u101x\u115x\u111x \u100x\u101x \u108x\u97x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u82x\u101x\u112x\u250x\u98x\u108x\u105x\u99x\u97x\u46x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u68x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u97x\u114x \u112x\u114x\u111x\u103x\u114x\u97x\u109x\u97x\u115x \u100x\u101x \u99x\u97x\u112x\u97x\u99x\u105x\u116x\u97x\u99x\u105x\u243x\u110x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u113x\u117x\u101x \u112x\u101x\u114x\u109x\u105x\u116x\u97x \u97x \u108x\u97x\u115x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x \u99x\u97x\u112x\u97x\u99x\u105x\u116x\u97x\u114x\u115x\u101x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u121x \u102x\u111x\u11