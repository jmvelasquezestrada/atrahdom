{\pard\plain\posx1655\posy1664\absw9300\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f4\cf1\fs21\expnd0\expndtw0\kerning0     \u73x\u73x\u46x\u79x\u66x\u74x\u69x\u84x\u73x\u86x\u79x\u83x}\par {\b0\i0\strike0\f4\cf1\fs21\expnd0\expndtw0\kerning0 \u79x\u98x\u106x\u101x\u116x\u105x\u118x\u111x \u71x\u101x\u110x\u101x\u114x\u97x\u108x\u58x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u67x\u111x\u110x\u116x\u101x\u120x\u116x\u117x\u97x\u108x\u105x\u122x\u97x\u99x\u105x\u243x\u110x \u115x\u111x\u99x\u105x\u97x\u108x\u44x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x \u121x \u112x\u111x\u108x\u237x\u116x\u105x\u99x\u97x\u44x \u101x\u110x \u108x\u97x \u113x\u117x\u101x \u99x\u111x\u104x\u97x\u98x\u105x\u116x\u97x\u110x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x \u103x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u116x\u101x\u99x\u97x\u115x\u44x \u100x\u101x\u110x\u116x\u114x\u111x \u100x\u101x \u108x\u97x \u80x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x \u69x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x\u109x\u101x\u110x\u116x\u101x \u65x\u99x\u116x\u105x\u118x\u97x \u121x \u101x\u110x\u99x\u97x\u114x\u103x\u97x\u100x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u100x\u101x \u108x\u97x \u114x\u101x\u112x\u114x\u111x\u100x\u117x\u99x\u99x\u105x\u243x\u110x\u44x \u97x\u110x\u116x\u101x \u108x\u111x\u115x \u114x\u101x\u116x\u111x\u115x \u121x \u100x\u101x\u115x\u97x\u102x\u237x\u111x\u115x \u100x\u101x \u108x\u97x \u99x\u114x\u105x\u115x\u105x\u115x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x \u109x\u117x\u110x\u100x\u105x\u97x\u108x \u113x\u117x\u101x \u97x\u102x\u101x\u99x\u116x\u97x \u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u46x}\par {\b0\i0\strike0\f4\cf2\fs21\expnd0\expndtw0\kerning0 \u79x