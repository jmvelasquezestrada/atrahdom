{\pard\plain\posx1655\posy1664\absw9299\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u72x\u111x\u121x \u97x \u99x\u97x\u115x\u105x \u49x\u52x \u97x\u241x\u111x\u115x \u100x\u101x \u108x\u97x \u102x\u105x\u114x\u109x\u97x \u100x\u101x \u108x\u111x\u115x \u65x\u99x\u117x\u101x\u114x\u100x\u111x\u115x \u100x\u101x \u80x\u97x\u122x\u44x \u108x\u97x\u115x \u99x\u97x\u117x\u115x\u97x\u115x \u113x\u117x\u101x \u111x\u114x\u105x\u103x\u105x\u110x\u97x\u114x\u111x\u110x \u108x\u97x \u103x\u117x\u101x\u114x\u114x\u97x\u44x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u97x\u117x\u110x \u115x\u105x\u103x\u117x\u101x\u110x \u115x\u105x\u110x \u114x\u101x\u115x\u111x\u108x\u118x\u101x\u114x\u115x\u101x\u44x \u112x\u111x\u114x\u113x\u117x\u101x \u110x\u111x \u115x\u111x\u108x\u111x \u102x\u117x\u101x \u112x\u111x\u114x \u108x\u97x \u116x\u105x\u101x\u114x\u114x\u97x\u44x \u112x\u111x\u114x \u108x\u97x\u115x \u102x\u117x\u101x\u114x\u122x\u97x\u115x \u100x\u101x \u112x\u114x\u111x\u100x\u117x\u99x\u99x\u105x\u243x\u110x\u44x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u101x\u108x \u99x\u111x\u110x\u116x\u114x\u111x\u108x \u100x\u101x\u108x \u112x\u111x\u100x\u101x\u114x\u44x \u115x\u105x\u110x\u111x \u102x\u117x\u101x \u112x\u97x\u114x\u97x \u109x\u97x\u110x\u116x\u101x\u110x\u101x\u114x \u117x\u110x\u97x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x\u44x \u100x\u101x\u115x\u105x\u110x\u102x\u111x\u114x\u109x\u97x\u100x\u97x\u44x \u99x\u105x\u101x\u103x\u97x \u121x \u115x\u111x\u114x\u100x\u97x\u44x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u115x\u105x\u110x \u99x\u97x\u112x\u97x\u99x\u105x\u100x\u97x\u100x \u100x\u101x \u111x\u114x\u103x\u97x\u110x\u105x\u122x\u97x\u99x\u105x\u243x\u110x \u121x \u100x\u101x \u101x\u120x\u112x\u114x\u101x\u115x\u97x\u114x \u111x \u112x\u114x\u111x\u112x\u111x\u110x\u101x\u114x\u44x \u97x\u110x\u116x\u101x \u108x\u111x \u113x\u117x\u101x \u