\u108x\u97x \u102x\u108x\u101x\u120x\u105x\u98x\u105x\u108x\u105x\u100x\u97x\u100x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u108x\u97x\u98x\u111x\u114x\u97x\u108x \u112x\u114x\u101x\u116x\u101x\u110x\u100x\u101x \u104x\u97x\u99x\u101x\u114x \u100x\u101x\u106x\u97x\u114x \u112x\u111x\u114x \u117x\u110x \u108x\u97x\u100x\u111x \u108x\u97x\u115x \u99x\u111x\u110x\u113x\u117x\u105x\u115x\u116x\u97x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u100x\u101x \u108x\u111x\u115x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u101x\u115x\u46x}\par }
{\pard\plain\posx1655\posy10784\absw9291\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u68x\u101x\u98x\u101x\u109x\u111x\u115x \u109x\u101x\u110x\u99x\u105x\u111x\u110x\u97x\u114x \u113x\u117x\u101x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x \u110x\u111x \u112x\u111x\u115x\u101x\u101x \u108x\u97x\u115x \u99x\u97x\u112x\u97x\u99x\u105x\u100x\u97x\u100x\u101x\u115x \u112x\u97x\u114x\u97x \u108x\u97x \u105x\u110x\u115x\u116x\u97x\u108x\u97x\u99x\u105x\u243x\u110x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u109x\u233x\u116x\u111x\u100x\u111x\u115x \u109x\u111x\u100x\u101x\u114x\u110x\u105x\u115x\u116x\u97x\u115x \u113x\u117x\u101x \u118x\u105x\u101x\u110x\u101x\u110x \u97x \u111x\u99x\u97x\u115x\u105x\u111x\u110x\u97x\u114x \u109x\u97x\u121x\u111x\u114x\u101x\u115x \u103x\u97x\u115x\u116x\u111x\u115x \u97x \u108x\u97x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x\u44x \u121x \u113x\u117x\u101x \u112x\u111x\u114x \u108x\u111x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u109x\u101x\u100x\u105x\u111x\u115x \u100x\u101x \u99x\u111x\u109x\u117x\u110x\u105x\u99x\u97x\u99x\u105x\u243x\u110x \u115x\u97x\u116x\u117x\u114x\u97x\u110x \u100x\u101x \u105x\u110x\u102x\u111x\u114x\u109x\u97x\u99x\u105x\u243x\u110x\u44x \u97x\u110x\u117x\u110x\u99x\u105x\u111x\u115x \u112x\u117x\u98x\u108x\u105x\u99x\u105x\u116x\u97x\u114x\u105x\u111x\u115x \u100x\u101x \u112x\u114x\u111x\u100x\u117x\u99x\u116x\u111x\u115x\u44x \u113x\u117x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u108x\u97x \u103x\u101x\u110x\u116x\u101x \u99x\u111x\u109x\u112x\u114x\u97x \u101x \u105x\u110x\u118x\u105x\u101x\u114x\u116x\u101x \u100x\u101x\u106x\u97x\u110x\u100x\u111x \u115x\u117x \u112x\u111x\u99x\u111x \u100x\u105x\u110x\u101x\u114x\u111x\u44x \u99x\u111x\u109x\u111x \u101x\u115x \u101x\u108x \u99x\u97x\u115x\u111x \u100x\u101x\u108x \u117x\u115x\u111x \u100x\u101x \u108x