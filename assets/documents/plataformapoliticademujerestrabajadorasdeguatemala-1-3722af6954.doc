{\pard\plain\posx1655\posy5650\absw9298\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u50x\u46x }{\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u67x\u111x\u110x\u100x\u105x\u99x\u105x\u111x\u110x\u101x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x\u58x }{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u69x\u120x\u105x\u115x\u116x\u101x \u117x\u110x\u97x \u100x\u101x\u115x\u112x\u114x\u101x\u111x\u99x\u117x\u112x\u97x\u99x\u105x\u243x\u110x \u112x\u111x\u114x \u112x\u97x\u114x\u116x\u101x \u100x\u101x \u108x\u111x\u115x \u101x\u109x\u112x\u108x\u101x\u97x\u100x\u111x\u114x\u101x\u115x \u121x \u108x\u97x\u115x \u112x\u97x\u114x\u116x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u103x\u117x\u98x\u101x\u114x\u110x\u97x\u109x\u101x\u110x\u116x\u97x\u108x\u101x\u115x \u101x\u110x \u99x\u117x\u109x\u112x\u108x\u105x\u114x \u99x\u111x\u110x \u108x\u111x\u115x \u101x\u115x\u116x\u225x\u110x\u100x\u97x\u114x\u101x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u101x\u115x\u116x\u97x\u98x\u108x\u101x\u99x\u105x\u100x\u111x\u115x \u101x\u110x \u108x\u97x \u110x\u111x\u114x\u109x\u97x\u116x\u105x\u118x\u97x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x \u101x \u105x\u110x\u116x\u101x\u114x\u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u44x \u101x\u110x \u99x\u117x\u97x\u110x\u116x\u111x \u97x\u108x \u100x\u101x\u114x\u101x\u99x\u104x\u111x \u97x \u108x\u97x \u115x\u97x\u108x\u117x\u100x \u111x\u99x\u117x\u112x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u44x \u108x\u97x\u115x \u99x\u111x\u110x\u100x\u105x\u99x\u105x\u111x\u110x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u102x\u97x\u118x\u111x\u114x\u97x\u98x\u108x\u101x\u115x \u112x\u97x\u114x\u97x \u108x\u97x\u115x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x\u44x \u101x\u108x \u100x\u101x\u114x\u101