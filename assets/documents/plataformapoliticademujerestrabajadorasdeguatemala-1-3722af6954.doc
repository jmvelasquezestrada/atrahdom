{\pard\plain\posx1655\posy2538\absw4637\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f4\cf1\fs21\expnd0\expndtw0\kerning0 \u67x\u79x\u78x\u67x\u76x\u85x\u83x\u73x\u79x\u78x\u69x\u83x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u70x\u97x\u108x\u116x\u97x \u100x\u101x \u111x\u112x\u111x\u114x\u116x\u117x\u110x\u105x\u100x\u97x\u100x\u101x\u115x \u100x\u101x \u101x\u109x\u112x\u108x\u101x\u111x \u97x\u110x\u116x\u101x \u108x\u97x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u99x\u114x\u105x\u115x\u105x\u115x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x \u109x\u117x\u110x\u100x\u105x\u97x\u108x \u113x\u117x\u101x \u97x\u102x\u101x\u99x\u116x\u97x \u97x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u46x}\par }
{\pard\plain\posx1655\posy2538\absw9142\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f4\cf1\fs21\expnd0\expndtw0\kerning0                                              \u82x\u69x\u67x\u79x\u77x\u69x\u78x\u84x\u65x\u67x\u73x\u79x\u78x\u69x\u83x}\par {\b0\i0\strike0\f4\cf1\fs21\expnd0\expndtw0\kerning0                                              }{\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u68x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u97x\u114x \u100x\u101x\u115x\u100x\u101x \u108x\u97x\u115x \u111x\u114x\u103x\u97x\u110x\u105x\u122x\u97x\u99x\u105x\u111x\u110x\u101x\u115x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0                                              \u115x\u111x\u99x\u105x\u97x\u108x\u101x\u115x \u121x \u115x\u105x\u110x\u100x\u105x\u99x\u97x\u108x\u101x\u115x\u44x \u108x\u97x \u99x\u97x\u112x\u97x\u99x\u105x\u100x\u97x\u100x \u100x\u101x \u117x\u110x\u97x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0                                              \u112x\u114x\u111x\u112x\u117x\u101x\u115x\u116x\u97x\u44x \u112x\u97x\u114x\u97x \u108x\u97x \u103x\u101x\u110x\u101x\u114x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u112x\u111x\u108x\u237x\u116x\u105x\u99x\u97x\u115x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0                                              \u112x\u250x\u98x\u108x\u105x\u99x\u97x\u115x \u113x\u117x\u101x \u112x\u101x\u114x\u109x\u105x\u116x\u97x\u110x \u108x\u97x \u103x\u101x\u110x\u101x\u114x\u97x\u99x\u105x\u243x\u110x \u100x\u101x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0                                              \u101x\u109x\u112x\u108x\u101x\u111x\u115x\u44x \u116x\u97x\u110x\u116x\u111x \u100x\u101x \u99x\u97x\u112x\u105x\u116x\u97x\u108x \u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x \u99x\u111x\u109x\u111x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0                                              \u101x\u120x\u116x\u114x\u97x\u110x\u106x\u101x\u114x\u111x\u46x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u69x\u108x \u105x\u110x\u99x\u117x\u109x\u112x\u108x\u105x\u109x\u105x\u101x\u110x\u116x\u111x \u97x \u108x\u97x\u115x \u110x\u111x\u114x\u109x\u97x\u116x\u105x\u118x\u97x\u115x\u80x\u114x\u111x\u112x\u111x\u110x\u101x\u114x \u108x\u97x \u99x\u114x\u101x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u109x\u101x\u115x\u97x\u115x \u100x\u101x \u100x\u105x\u225x\u108x\u111x\u103x\u111x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x \u101x \u105x\u110x\u116x\u101x\u114x\u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x\u46x \u80x\u111x\u114x\u116x\u233x\u99x\u110x\u105x\u99x\u111x \u121x \u101x\u102x\u105x\u99x\u105x\u101x\u110x\u116x\u101x\u44x \u101x\u110x\u116x\u114x\u101x \u115x\u111x\u99x\u105x\u101x\u100x\u97x\u100x\u44x \u99x\u105x\u118x\u105x\u108x\u44x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u112x\u97x\u114x\u116x\u101x \u100x\u101x \u101x\u109x\u112x\u108x\u101x\u97x\u100x\u111x\u114x\u101x\u115x \u101x\u110x \u99x\u117x\u97x\u110x\u116x\u111x \u97x\u58x\u115x\u101x\u99x\u116x\u111x\u114x \u101x\u109x\u112x\u108x\u101x\u97x\u100x\u111x\u114x \u121x \u108x\u97x\u115x \u116x\u114x\u101x\u115x \u105x\u110x\u115x\u116x\u97x\u110x\u99x\u105x\u97x\u115x \u100x\u101x\u108x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0 \u73x\u110x\u99x\u117x\u109x\u112x\u108x\u105x\u109x\u105x\u101x\u110x\u116x\u111x \u97x\u108x \u115x\u97x\u108x\u97x\u114x\u105x\u111x \u109x\u237x\u110x\u105x\u109x\u111x\u46x\u112x\u111x\u100x\u101x\u114x \u100x\u101x\u108x \u69x\u115x\u116x\u97x\u100x\u111x\u44x \u97x \u102x\u105x\u110x \u100x\u101x \u97x\u98x\u111x\u114x\u100x\u97x\u114x \u108x\u97x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u49x\u46x \u73x\u110x\u99x\u117x\u109x\u112x\u108x\u105x\u101x\u110x\u100x\u111x \u97x\u108x \u112x\u97x\u103x\u111x \u100x\u101x\u112x\u114x\u111x\u98x\u108x\u101x\u109x\u225x\u116x\u105x\u99x\u97x \u100x\u101x \u108x\u97x \u118x\u105x\u111x\u108x\u97x\u116x\u111x\u114x\u105x\u97x \u97x\u108x \u100x\u101x\u114x\u101x\u99x\u104x\u111x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0         \u112x\u114x\u101x\u115x\u116x\u97x\u99x\u105x\u111x\u110x\u101x\u115x\u46x\u108x\u97x\u98x\u111x\u114x\u97x\u108x\u44x \u103x\u101x\u110x\u101x\u114x\u97x\u110x\u100x\u111x \u99x\u111x\u110x\u118x\u101x\u110x\u105x\u111x\u115x \u121x \u97x\u99x\u117x\u101x\u114x\u100x\u111x\u115x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u50x\u46x \u73x\u110x\u99x\u117x\u109x\u112x\u108x\u105x\u109x\u105x\u101x\u110x\u116x\u111x \u97x\u108x \u100x\u101x\u114x\u101x\u99x\u104x\u111x \u100x\u101x\u100x\u101x \u99x\u97x\u114x\u225x\u99x\u116x\u101x\u114x \u103x\u117x\u98x\u101x\u114x\u110x\u97x\u116x\u105x\u118x\u111x \u44x \u108x\u101x\u103x\u105x\u115x\u108x\u97x\u116x\u105x\u118x\u111x\u44x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0         \u100x\u101x\u115x\u99x\u97x\u110x\u115x\u111x\u115x\u44x \u102x\u101x\u114x\u105x\u97x\u100x\u111x\u115x \u121x \u97x\u115x\u117x\u101x\u116x\u111x\u115x\u46x\u106x\u117x\u100x\u105x\u99x\u105x\u97x\u108x\u44x \u99x\u111x\u110x \u99x\u97x\u112x\u97x\u99x\u105x\u100x\u97x\u100x \u100x\u101x \u115x\u97x\u110x\u99x\u105x\u111x\u110x\u97x\u114x\u44x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u51x\u46x \u70x\u97x\u108x\u116x\u97x \u100x\u101x \u83x\u97x\u108x\u117x\u100x \u79x\u99x\u117x\u112x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u46x\u97x\u100x\u109x\u105x\u110x\u105x\u115x\u116x\u114x\u97x\u116x\u105x\u118x\u97x\u44x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x \u121x \u112x\u101x\u110x\u97x\u108x\u109x\u101x\u110x\u116x\u101x \u97x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u52x\u46x \u80x\u114x\u101x\u118x\u101x\u110x\u99x\u105x\u243x\u110x \u100x\u101x \u97x\u99x\u99x\u105x\u100x\u101x\u110x\u116x\u101x\u115x\u46x\u108x\u111x\u115x \u114x\u101x\u115x\u112x\u111x\u110x\u115x\u97x\u98x\u108x\u101x\u115x\u46x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u53x\u46x \u80x\u114x\u111x\u116x\u101x\u99x\u99x\u105x\u243x\u110x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u44x \u99x\u111x\u110x \u104x\u101x\u114x\u114x\u97x\u109x\u105x\u101x\u110x\u116x\u97x\u115x \u81x\u117x\u101x \u112x\u101x\u114x\u109x\u105x\u116x\u97x\u110x \u101x\u108x \u99x\u117x\u109x\u112x\u108x\u105x\u109x\u101x\u110x\u116x\u111x \u100x\u101x \u108x\u97x\u115x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0         \u121x \u101x\u113x\u117x\u105x\u112x\u111x\u115x \u97x\u100x\u101x\u99x\u117x\u97x\u100x\u111x\u115x\u46x\u110x\u111x\u114x\u109x\u97x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x \u101x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u54x\u46x \u86x\u105x\u111x\u108x\u101x\u110x\u99x\u105x\u97x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u46x\u105x\u110x\u116x\u101x\u114x\u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x \u113x\u117x\u101x \u104x\u97x\u110x \u115x\u105x\u100x\u111x \u114x\u97x\u116x\u105x\u102x\u105x\u99x\u97x\u100x\u97x\u115x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u55x\u46x \u65x\u99x\u111x\u115x\u111x \u121x \u104x\u111x\u115x\u116x\u105x\u103x\u97x\u109x\u105x\u101x\u110x\u116x\u111x \u83x\u101x\u120x\u117x\u97x\u108x\u46x\u112x\u111x\u114x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u44x \u121x \u100x\u101x \u108x\u111x\u115x \u67x\u111x\u110x\u118x\u101x\u110x\u105x\u111x\u115x \u121x}\par {\b0\i0\strike0\f7\cf0\fs21\expnd0\expndtw0\kerning0      \u56x\u46x \u86x\u105x\u111x\u108x\u97x\u99x\u105x\u243x\u110x \u97x\u108x \u100x\u101x\u114x\u101x\u99x\u104x\u111x \u97x \u108x\u97x\u84x\u114x\u97x\u116x\u97x\u100x\u111x\u115x \u97x \u102x\u97x\u118x\u111x\u114x \u100x\u101x \u108x\u97x