ning0 \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u101x\u110x\u102x\u101x\u114x\u109x\u101x\u100x\u97x\u100x\u101x\u115x\u44x \u99x\u111x\u110x \u109x\u101x\u100x\u105x\u99x\u105x\u110x\u97x\u115x \u103x\u101x\u110x\u233x\u114x\u105x\u99x\u97x\u115x\u44x \u111x \u114x\u101x\u109x\u101x\u100x\u105x\u111x\u115x \u99x\u97x\u115x\u101x\u114x\u111x\u115x\u46x \u78x\u111x \u115x\u111x\u110x \u115x\u117x\u106x\u101x\u116x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u97x \u99x\u114x\u233x\u100x\u105x\u116x\u111x\u115x \u112x\u111x\u114x \u110x\u111x \u99x\u111x\u110x\u116x\u97x\u114x \u99x\u111x\u110x \u105x\u110x\u103x\u114x\u101x\u115x\u111x \u113x\u117x\u101x \u108x\u101x\u115x \u103x\u97x\u114x\u97x\u110x\u116x\u105x\u99x\u101x \u101x\u108x \u112x\u97x\u103x\u111x \u112x\u117x\u110x\u116x\u117x\u97x\u108x\u46x \u69x\u115x\u116x\u97x \u99x\u108x\u97x\u115x\u101x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u99x\u114x\u233x\u100x\u105x\u116x\u111x\u115x \u113x\u117x\u101x \u115x\u111x\u110x \u116x\u97x\u110x\u116x\u111x \u100x\u101x \u98x\u97x\u110x\u99x\u111x\u115x\u44x \u99x\u111x\u111x\u112x\u101x\u114x\u97x\u116x\u105x\u118x\u97x\u115x \u111x \u116x\u105x\u101x\u110x\u100x\u97x\u115x \u100x\u101x \u101x\u108x\u101x\u99x\u116x\u114x\u111x\u100x\u111x\u109x\u233x\u115x\u116x\u105x\u99x\u111x\u115x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u80x\u111x\u114x \u108x\u111x \u113x\u117x\u101x \u110x\u111x \u116x\u105x\u101x\u110x\u101x\u110x \u104x\u111x\u114x\u97x\u114x\u105x\u111x\u115x \u100x\u101x \u106x\u111x\u114x\u110x\u97x\u100x\u97x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x\u44x \u101x\u108x\u108x\u97x\u115x \u109x\u105x\u115x\u109x\u97x\u115x \u115x\u111x\u110x \u113x\u117x\u105x\u101x\u110x\u101x\u115x \u115x\u101x \u108x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u105x\u109x\u112x\u111x\u110x\u101x\u110x\u44x \u108x\u97x\u115