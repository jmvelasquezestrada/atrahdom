{\pard\plain\posx1655\posy2234\absw9299\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u68x\u101x\u115x\u112x\u117x\u233x\u115x \u100x\u101x\u108x \u67x\u111x\u110x\u103x\u114x\u101x\u115x\u111x \u100x\u101x \u77x\u117x\u106x\u101x\u114x\u101x\u115x \u84x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x \u100x\u101x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u44x \u101x\u108x \u99x\u117x\u97x\u108x \u99x\u111x\u111x\u114x\u100x\u105x\u110x\u97x\u109x\u111x\u115x \u121x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u97x\u109x\u111x\u115x \u101x\u110x \u101x\u108x \u109x\u101x\u115x \u100x\u101x \u109x\u97x\u121x\u111x \u50x\u48x\u49x\u48x\u44x \u110x\u111x\u115x \u112x\u114x\u111x\u112x\u117x\u115x\u105x\u109x\u111x\u115x \u101x\u108x\u97x\u98x\u111x\u114x\u97x\u114x \u117x\u110x\u97x \u112x\u108x\u97x\u116x\u97x\u102x\u111x\u114x\u109x\u97x \u113x\u117x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u114x\u101x\u99x\u111x\u103x\u105x\u101x\u114x\u97x \u100x\u101x \u109x\u97x\u110x\u101x\u114x\u97x \u99x\u111x\u110x\u116x\u117x\u110x\u100x\u101x\u110x\u116x\u101x\u44x \u108x\u97x \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x\u44x \u114x\u101x\u112x\u114x\u101x\u115x\u101x\u110x\u116x\u97x\u100x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u112x\u111x\u114x \u108x\u97x\u115x \u111x\u114x\u103x\u97x\u110x\u105x\u122x\u97x\u99x\u105x\u111x\u110x\u101x\u115x\u44x \u113x\u117x\u101x \u112x\u97x\u114x\u116x\u105x\u99x\u105x\u112x\u97x\u114x\u111x\u110x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u69x\u108x\u97x\u98x\u111x\u114x\u97x\u114x \u101x\u115x\u116x\u97x \u112x\u108x\u97x\u116x\u97x\u102x\u111x\u114x\u109x\u97x \u100x\u101x\u115x\u100x\u101x \u110x\u117x\u101x\u115x\u116x\u114x\u111x \u112x\u101x\u110x\u115x\u97x\u109x\u105x\u101x\u110x\u116x\u111x\u44x \u110x\u117x\u101x\u115x\u116x\u114x\u111x \u115x\u101x\u110x\u116x\u105x\u114x\u44x \u121x \u99x\u111x\u101x\u120x\u105x\u115x\u116x\u101x\u110x\u99x\u105x\u97x \u99x\u111x\u109x\u111x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u103x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u116x\u101x\u99x\u97x\u115x\u44x \u110x\u111x\u115x \u108x\u108x\u101x\u118x\u97x \u97x \u112x\u108x\u97x\u115x\u109x\u97x\u114x \u117x\u110x\u97x \u114x\u101x\u97x\u108x\u105x\u100x\u97x\u100x \u113x\u117x\u101x \u118x\u105x\u118x\u105x\u109x\u111x\u115x \u100x\u237x\u97x \u97x \u100x\u237x\u97x \u99x\u111x\u109x\u111x \u109x\u117x\u106x\u101x\u114x\u101x\u115x\u44x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u109x\u97x\u100x\u114x\u101x\u115x\u44x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x\u44x \u99x\u105x\u117x\u100x\u97x\u100x\u97x\u110x\u97x\u115x\u44x \u99x\u111x\u110x \u100x\u101x\u114x\u101x\u99x\u104x\u111x\u115x \u121x \u111x\u98x\u108x\u105x\u103x\u97x\u99x\u105x\u111x\u110x\u101x\u115x\u46x \u89x \u113x\u117x\u101x \u101x\u110x \u108x\u97x \u114x\u101x\u97x\u108x\u105x\u100x\u97x\u100x \u110x\u111x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u115x\u101x\u110x\u116x\u105x\u109x\u111x\u115x \u118x\u237x\u99x\u116x\u105x\u109x\u97x\u115x \u100x\u101x \u117x\u110x\u97x \u118x\u105x\u111x\u108x\u101x\u110x\u99x\u105x\u97x \u113x\u117x\u101x \u97x\u116x\u114x\u97x\u118x\u105x\u101x\u115x\u97x \u116x\u111x\u100x\u97x\u115x \u108x\u97x\u115x \u101x\u115x\u102x\u101x\u114x\u97x\u115x \u100x\u101x \u108x\u97x \u118x\u105x\u100x\u97x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u72x\u101x\u109x\u111x\u115x \u116x\u101x\u110x\u105x\u100x\u111x \u114x\u101x\u116x\u111x\u115x\u44x \u97x\u115x\u117x\u109x\u105x\u100x\u111x \u99x\u111x\u109x\u112x\u114x\u111x\u109x\u105x\u115x\u111x\u115x\u44x \u100x\u101x\u114x\u114x\u105x\u98x\u97x\u109x\u111x\u115x \u100x\u101x\u115x\u97x\u102x\u237x\u111x\u115x\u44x \u99x\u97x\u100x\u97x \u100x\u237x\u97x \u112x\u111x\u114x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u101x\u120x\u105x\u115x\u116x\u101x\u110x\u99x\u105x\u97x\u44x \u112x\u111x\u114x \u115x\u111x\u98x\u114x\u101x\u118x\u105x\u118x\u105x\u114x \u101x\u110x \u117x\u110x\u97x \u99x\u111x\u110x\u118x\u117x\u108x\u115x\u105x\u243x\u110x \u115x\u111x\u99x\u105x\u97x\u108x\u44x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x\u44x \u112x\u111x\u108x\u237x\u116x\u105x\u99x\u97x \u121x \u97x\u109x\u98x\u105x\u101x\u110x\u116x\u97x\u44x \u101x\u110x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u100x\u111x\u110x\u100x\u101x \u99x\u97x\u100x\u97x \u117x\u110x\u111x \u100x\u101x \u101x\u115x\u116x\u111x\u115x \u99x\u111x\u109x\u112x\u111x\u110x\u101x\u110x\u116x\u101x\u115x \u115x\u111x\u110x \u118x\u105x\u110x\u99x\u117x\u108x\u97x\u110x\u116x\u101x\u115x \u101x\u110x\u116x\u114x\u101x \u115x\u105x\u44x \u121x\u97x \u113x\u117x\u101x \u117x\u110x\u111x \u115x\u105x\u110x \u101x\u108x \u111x\u116x\u114x\u111x\u44x \u110x\u111x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u110x\u111x\u115x \u112x\u101x\u114x\u109x\u105x\u116x\u101x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u97x\u114x\u110x\u111x\u115x \u99x\u111x\u109x\u111x \u109x\u117x\u106x\u101x\u114x\u101x\u115x\u44x \u121x \u99x\u111x\u109x\u111x \u112x\u97x\u237x\u115x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u65x\u99x\u116x\u117x\u97x\u108x\u109x\u101x\u110x\u116x\u101x \u115x\u111x\u98x\u114x\u101x \u112x\u97x\u115x\u97x\u109x\u111x\u115x \u108x\u97x \u109x\u105x\u116x\u97x\u100x \u100x\u101x \u108x\u97x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x\u44x \u115x\u111x\u109x\u111x\u115x \u108x\u97x\u115x \u109x\u111x\u116x\u111x\u114x\u97x\u115x \u100x\u101x \u108x\u97x \u101x\u99x\u111x\u110x\u111x\u109x\u237x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u101x\u110x \u101x\u108x \u112x\u97x\u237x\u115x\u44x \u108x\u97x\u115x \u103x\u101x\u110x\u101x\u114x\u97x\u100x\u111x\u114x\u97x\u115x \u100x\u101x \u108x\u97x \u99x\u117x\u108x\u116x\u117x\u114x\u97x\u44x \u100x\u101x\u108x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x\u44x \u121x \u97x \u108x\u97x \u118x\u101x\u122x \u115x\u111x\u109x\u111x\u115x \u100x\u105x\u115x\u99x\u114x\u105x\u109x\u105x\u110x\u97x\u100x\u97x\u115x \u101x\u110x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u117x\u110x\u97x \u115x\u111x\u99x\u105x\u101x\u100x\u97x\u100x \u99x\u117x\u108x\u116x\u117x\u114x\u97x\u108x\u109x\u101x\u110x\u116x\u101x \u112x\u97x\u116x\u114x\u105x\u97x\u114x\u99x\u97x\u108x\u44x \u101x\u110x \u108x\u97x \u113x\u117x\u101x \u109x\u117x\u99x\u104x\u97x\u115x \u99x\u97x\u114x\u103x\u97x\u115x \u100x\u101x\u112x\u101x\u110x\u100x\u101x\u110x \u100x\u101x \u110x\u117x\u101x\u115x\u116x\u114x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u109x\u97x\u110x\u111x\u115x\u44x \u100x\u101x \u110x\u117x\u101x\u115x\u116x\u114x\u97x\u115x \u114x\u101x\u115x\u112x\u111x\u110x\u115x\u97x\u98x\u105x\u108x\u105x\u100x\u97x\u100x\u101x\u115x\u44x \u121x\u97x \u113x\u117x\u101x \u101x\u110x \u101x\u108x \u104x\u111x\u103x\u97x\u114x\u44x \u115x\u111x\u109x\u111x\u115x \u101x\u110x\u99x\u97x\u114x\u103x\u97x\u100x\u97x\u115x \u100x\u101x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u114x\u101x\u112x\u114x\u111x\u100x\u117x\u99x\u99x\u105x\u243x\u110x \u121x \u115x\u111x\u109x\u111x\u115x \u112x\u111x\u114x\u116x\u97x\u100x\u111x\u114x\u97x\u115x \u100x\u101x \u108x\u97x \u101x\u99x\u111x\u110x\u111x\u109x\u237x\u97x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u78x\u111x\u115x \u104x\u97x \u116x\u111x\u99x\u97x\u100x\u111x \u118x\u105x\u118x\u105x\u114x\u44x \u121x \u97x\u115x\u105x\u109x\u105x\u108x\u9