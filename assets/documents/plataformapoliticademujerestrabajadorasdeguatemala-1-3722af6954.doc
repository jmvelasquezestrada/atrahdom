{\pard\plain\posx2005\posy5650\absw8948\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u54x\u46x \u76x\u97x \u67x\u111x\u110x\u118x\u101x\u110x\u99x\u105x\u243x\u110x \u115x\u111x\u98x\u114x\u101x \u108x\u97x \u69x\u108x\u105x\u109x\u105x\u110x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u116x\u111x\u100x\u97x\u115x \u108x\u97x\u115x \u102x\u111x\u114x\u109x\u97x\u115x \u100x\u101x \u68x\u105x\u115x\u99x\u114x\u105x\u109x\u105x\u110x\u97x\u99x\u105x\u243x\u110x \u99x\u111x\u110x\u116x\u114x\u97x \u108x\u97x \u77x\u117x\u106x\u101x\u114x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u97x\u100x\u111x\u112x\u116x\u97x\u100x\u97x \u112x\u111x\u114x \u108x\u97x \u65x\u115x\u97x\u109x\u98x\u108x\u101x\u97x \u71x\u101x\u110x\u101x\u114x\u97x\u108x \u100x\u101x \u108x\u97x\u115x \u78x\u97x\u99x\u105x\u111x\u110x\u101x\u115x \u85x\u110x\u105x\u100x\u97x\u115x \u101x\u108x \u50x\u50x \u100x\u101x \u109x\u97x\u121x\u111x \u100x\u101x \u49x\u57x\u57x\u53x \u40x\u67x\u69x\u68x\u65x\u87x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u112x\u111x\u114x \u115x\u117x\u115x \u115x\u105x\u103x\u108x\u97x\u115x \u101x\u110x \u105x\u110x\u103x\u108x\u101x\u115x\u41x\u44x \u113x\u117x\u101x \u114x\u101x\u105x\u116x\u101x\u114x\u97x \u113x\u117x\u101x \u108x\u97x \u109x\u225x\u120x\u105x\u109x\u97x \u112x\u97x\u114x\u116x\u105x\u99x\u105x\u112x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u108x\u97x \u109x\u117x\u106x\u101x\u114x\u44x \u101x\u110x \u105x\u103x\u117x\u97x\u108x\u100x\u97x\u100x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u100x\u101x \u99x\u111x\u110x\u100x\u105x\u99x\u105x\u111x\u110x\u101x\u115x \u113x\u117x\u101x \u101x\u108x \u104x\u111x\u109x\u98x\u114x\u101x\u44x \u101x\u110x \u116x\u111x\u100x\u111x\u115x \u108x\u111x\u115x \u99x\u97x\u109x\u112x\u111x\u115x\u44x \u101x\u115x \u105x\u110x\u100x\u105x\u115x\u112x\u101x\u110x\u115x\u97x\u98x\u108x\u101x \u112x\u97x\u114