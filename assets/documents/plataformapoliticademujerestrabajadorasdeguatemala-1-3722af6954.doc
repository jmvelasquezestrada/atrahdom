15x\u116x\u97x \u102x\u117x\u101x \u115x\u111x\u108x\u97x\u109x\u101x\u110x\u116x\u101x \u117x\u110x\u97x \u102x\u111x\u114x\u109x\u97x \u100x\u101x\u44x \u100x\u101x\u106x\u97x\u114x \u100x\u101x \u115x\u101x\u114x \u117x\u110x\u97x \u99x\u111x\u108x\u111x\u110x\u105x\u97x \u101x\u115x\u112x\u97x\u241x\u111x\u108x\u97x\u44x \u112x\u97x\u114x\u97x \u116x\u101x\u110x\u101x\u114x \u117x\u110x \u112x\u111x\u100x\u101x\u114x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u121x \u99x\u111x\u110x\u116x\u114x\u111x\u108x \u100x\u101x \u108x\u111x\u115x \u109x\u101x\u100x\u105x\u111x\u115x \u100x\u101x \u112x\u114x\u111x\u100x\u117x\u99x\u99x\u105x\u243x\u110x\u44x \u121x \u108x\u97x \u101x\u120x\u112x\u108x\u111x\u116x\u97x\u99x\u105x\u243x\u110x\u44x \u112x\u97x\u114x\u97x \u110x\u111x \u114x\u101x\u110x\u100x\u105x\u114x \u109x\u97x\u115x \u116x\u114x\u105x\u98x\u117x\u116x\u111x\u115x \u97x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u99x\u111x\u114x\u111x\u110x\u97x \u101x\u115x\u112x\u97x\u241x\u111x\u108x\u97x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0     }{\b0\i0\strike0\f7\cf3\fs21\expnd0\expndtw0\kerning0 \u77x\u105x\u101x\u110x\u116x\u114x\u97x\u115x \u113x\u117x\u101x \u109x\u117x\u99x\u104x\u97x \u106x\u117x\u118x\u101x\u110x\u116x\u117x\u100x \u100x\u101x \u104x\u111x\u121x\u44x \u100x\u101x\u115x\u99x\u111x\u110x\u111x\u99x\u101x\u110x \u108x\u111x\u115x \u111x\u114x\u105x\u103x\u105x\u110x\u101x\u115x \u100x\u101x \u108x\u97x \u103x\u117x\u101x\u114x\u114x\u97x\u44x \u104x\u111x\u121x \u112x\u105x\u101x\u110x\u115x\u97x\u110x}\par {\b0\i0\strike0\f7\cf3\fs21\expnd0\expndtw0\kerning0    \u113x\u117x\u101x \u115x\u101x\u114x\u237x\u97x \u113x\u117x\u105x\u122x\u225x \u109x\u101x\u106x\u111x\u114x \u115x\u101x\u114x \u100x\u101x\u112x\u101x\u110x\u100x\u105x\u101x\u110x\u116x\u101x\u115x \u100x\u101x \u108x\u111x\u115x \u101x\u115x\u112x\u97x\u241x\u111x\u108x\u101x\u115x \u97x\u250x\u110x \u121x \u110x\u111x \u118x\u105x\u118x\u105x\u114x \u101x\u120x\u112x\u108x\u111x\u116x\u97x\u100x\u111x\u115x \u112x\u111x\u114x \u108x\u111x\u115x}\par {\b0\i0\strike0\f7\cf3\fs21\expnd0\expndtw0\kerning0           \u109x\u105x\u115x\u109x\u111x\u115x \u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x\u44x \u121x \u115x\u101x\u114x\u237x\u97x \u117x\u110x\u97x \u114x\u101x\u115x\u112x\u111x\u110x\u115x\u97x\u98x\u105x\u108x\u105x\u100x\u97x\u100x \u100x\u101x \u69x\u115x\u112x\u97x\u241x\u97x \u103x\u97x\u114x\u97x\u110x\u116x\u105x\u122x\u97x\u114x \u108x\u97x \u115x\u97x\u108x\u117x\u100x \u121x \u108x\u97x}\par {\b0\i0\strike0\f7\cf3\fs21\expnd0\expndtw0\kerning0      \u101x\u100x\u117x\u99x\u97x\u99x\u105x\u243x\u110x \u101x\u110x \u101x\u108x \u112x\u97x\u237x\u115x\u44x \u99x\u111x\u109x\u111x \u108x\u97x\u115x \u112x\u114x\u105x\u110x\u99x\u105x\u112x\u97x\u108x\u101x\u115x \u99x\u111x\u108x\u117x\u109x\u110x\u97x\u115x \u100x\u101x\u108x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x\u44x \u99x\u111x\u109x\u111x \u108x\u111x \u104x\u97x\u110x \u104x\u101x\u99x\u104x\u111x}\par {\b0\i0\strike0\f7\cf3\fs21\expnd0\expndtw0\kerning0     \u112x\u97x\u237x\u115x\u101x\u115x \u99x\u111x\u109x\u111x \u67x\u104x\u105x\u110x\u97x\u44x \u113x\u117x\u101x \u97x\u104x\u111x\u114x\u97x \u115x\u111x\u110x \u97x\u108x\u116x\u97x\u109x\u101x\u110x\u116x\u101x \u105x\u110x\u100x\u117x\u115x\u116x\u114x\u105x\u97x\u108x\u105x\u122x\u97x\u100x\u111x\u115x \u99x\u111x\u110x \u117x\u110x\u97x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x \u115x\u97x\u110x\u97x \u121x}\par {\b0\i0\strike0\f7\cf3\fs21\expnd0\expndtw0\kerning0                                       \u99x\u111x\u110x \u109x\u117x\u99x\u104x\u97x \u102x\u111x\u114x\u109x\u97x\u99x\u105x\u243x\u110x \u97x\u99x\u97x\u100x\u233x\u109x\u105x\u99x\u97x \u112x\u114x\u111x\u102x\u101x\u115x\u105x\u111x\u110x\u97x\u108x \u115x\u117x\u112x\u101x\u114x\u105x\u111x\u114x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u80x\u101x\u114x\u111x \u100x\u101x \u105x\u103x\u117x\u97x\u108x \u115x\u101x \u100x\u105x\u106x\u111x \u113x\u117x\u101x \u108x\u111x\u115x \u65x\u99x\u117x\u101x\u114x\u100x\u111x\u115x \u100x\u101x \u80x\u97x\u122x \u103x\u101x\u110x\u101x\u114x\u97x\u114x\u237x\u97x\u110x \u117x\u110x\u97x \u103x\u117x\u101x\u114x\u114x\u97x \u100x\u105x\u102x\u101x\u114x\u101x\u110x\u116x\u101x \u121x\u97x \u113x\u117x\u101x \u101x\u115x\u116x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u110x\u111x \u115x\u101x\u114x\u237x\u97x \u100x\u101x\u102x\u105x\u110x\u105x\u100x\u97x \u101x\u110x\u116x\u114x\u101x \u108x\u97x \u103x\u117x\u101x\u114x\u114x\u105x\u108x\u108x\u97x \u121x \u101x\u108x \u101x\u106x\u233x\u114x\u99x\u105x\u116x\u111x\u44x \u115x\u105x\u110x\u111x \u115x\u101x\u114x\u237x\u97x \u112x\u111x\u114x \u102x\u117x\u101x\u114x\u122x\u97x\u115x \u111x\u98x\u115x\u99x\u117x\u114x\u97x\u115x\u44x \u110x\u111x \u104x\u97x\u98x\u114x\u237x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u117x\u110x \u101x\u110x\u101x\u109x\u105x\u103x\u111x \u100x\u101x\u102x\u105x\u110x\u105x\u100x\u111x\u44x \u112x\u111x\u114x\u113x\u117x\u101x \u104x\u111x\u121x \u110x\u111x\u115x \u101x\u110x\u99x\u111x\u110x\u116x\u114x\u97x\u109x\u111x\u115x \u101x\u110x \u102x\u117x\u101x\u103x\u111x\u115x \u99x\u114x\u117x\u122x\u97x\u100x\u111x\u115x\u44x \u115x\u105x\u110x \u105x\u109x\u112x\u111x\u114x\u116x\u97x\u114x \u100x\u111x\u110x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u115x\u111x\u110x \u108x\u111x\u115x \u99x\u97x\u109x\u112x\u111x\u115x \u100x\u101x \u98x\u97x\u116x\u97x\u108x\u108x\u97x\u44x \u101x\u110x \u112x\u108x\u101x\u110x\u97x\u115x \u99x\u105x\u117x\u100x\u97x\u100x\u101x\u115x\u44x \u121x \u115x\u105x\u110x \u100x\u101x\u102x\u105x\u110x\u105x\u114x \u97x \u113x\u117x\u105x\u101x\u110x \u115x\u101x \u97x\u116x\u97x\u99x\u97x\u46x}\par }
