x\u97x \u109x\u97x\u110x\u101x\u114x\u97x\u44x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u100x\u105x\u115x\u99x\u114x\u105x\u109x\u105x\u110x\u97x\u116x\u111x\u114x\u105x\u97x \u121x \u97x\u108x\u116x\u97x\u109x\u101x\u110x\u116x\u101x \u112x\u101x\u114x\u106x\u117x\u100x\u105x\u99x\u105x\u97x\u108x\u101x\u115x\u44x \u112x\u111x\u114x\u113x\u117x\u101x \u101x\u110x \u108x\u117x\u103x\u97x\u114x \u100x\u101x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x \u104x\u97x\u110x \u103x\u101x\u110x\u101x\u114x\u97x\u100x\u111x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u112x\u111x\u98x\u114x\u101x\u122x\u97x\u46x \u83x\u117x\u109x\u97x\u100x\u111x \u97x \u101x\u108x\u108x\u111x\u44x \u108x\u97x \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u100x\u101x\u108x \u100x\u101x\u115x\u101x\u109x\u112x\u108x\u101x\u111x\u44x \u112x\u114x\u111x\u100x\u117x\u99x\u116x\u111x \u100x\u101x \u108x\u97x \u99x\u114x\u105x\u115x\u105x\u115x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x\u44x \u121x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u102x\u97x\u108x\u116x\u97x \u100x\u101x \u117x\u110x \u99x\u111x\u109x\u112x\u114x\u111x\u109x\u105x\u115x\u111x \u99x\u111x\u110x \u108x\u97x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x \u112x\u111x\u114x \u112x\u97x\u114x\u116x\u101x \u100x\u101x \u108x\u111x\u115x \u116x\u114x\u101x\u115x \u112x\u111x\u100x\u101x\u114x\u101x\u115x \u100x\u101x\u108x \u69x\u115x\u116x\u97x\u100x\u111x\u44x \u100x\u101x \u115x\u101x\u114x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u102x\u105x\u108x\u101x\u115x \u121x \u103x\u97x\u114x\u97x\u110x\u116x\u101x\u115x \u100x\u101x \u108x\u97x \u112x\u114x\u111x\u116x\u101x\u99x\u99x\u105x\u243x\u110x \u121x \u99x\u117x\u109x\u112x\u108x\u105x\u109x\u105x\u101x\u110x\u116x\u111x \u100x\u101x \u108x\u97x\u115x \u110x\u111x\u114x\u109x\u97x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u110x\u97x\u99x\u105x