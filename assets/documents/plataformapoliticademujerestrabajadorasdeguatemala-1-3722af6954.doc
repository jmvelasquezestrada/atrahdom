4x\u111x\u115x\u97x\u115x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x\u109x\u101x\u110x\u116x\u101x\u44x \u113x\u117x\u105x\u101x\u110x\u101x\u115x \u116x\u111x\u109x\u97x\u110x \u97x \u102x\u97x\u109x\u105x\u108x\u105x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u99x\u111x\u109x\u112x\u108x\u101x\u116x\u97x\u115x \u97x \u115x\u117x\u115x \u115x\u101x\u114x\u118x\u105x\u99x\u105x\u111x\u115x\u46x \u80x\u111x\u114x \u108x\u111x \u113x\u117x\u101x \u108x\u97x\u115x \u110x\u105x\u241x\u97x\u115x \u115x\u111x\u110x \u112x\u97x\u114x\u97x \u108x\u111x\u115x \u111x\u102x\u105x\u99x\u105x\u111x\u115x \u100x\u111x\u109x\u233x\u115x\u116x\u105x\u99x\u111x\u115x\u44x \u97x\u108x \u105x\u103x\u117x\u97x\u108x \u113x\u117x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u108x\u97x\u115x \u109x\u97x\u100x\u114x\u101x\u115x\u44x \u121x \u108x\u111x\u115x \u104x\u111x\u109x\u98x\u114x\u101x\u115x \u97x \u108x\u97x\u115x \u116x\u97x\u114x\u101x\u97x\u115x \u100x\u101x\u108x \u99x\u97x\u109x\u112x\u111x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u69x\u110x \u97x\u108x\u103x\u117x\u110x\u111x\u115x \u109x\u117x\u110x\u105x\u99x\u105x\u112x\u105x\u111x\u115x \u100x\u111x\u110x\u100x\u101x \u101x\u108x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x \u121x \u108x\u97x \u116x\u101x\u99x\u110x\u111x\u108x\u111x\u103x\u237x\u97x \u104x\u97x \u108x\u108x\u101x\u103x\u97x\u100x\u111x\u44x \u112x\u111x\u114x \u109x\u101x\u100x\u105x\u111x \u100x\u101x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u116x\u101x\u108x\u101x\u118x\u105x\u115x\u105x\u243x\u110x\u44x \u108x\u97x\u115x \u99x\u111x\u109x\u117x\u110x\u105x\u99x\u97x\u99x\u105x\u111x\u110x\u101x\u115x\u44x \u104x\u97x\u110x \u104x\u101x\u99x\u104x\u111x \u113x\u117x\u101x \u102x\u97x\u109x\u105x\u108x\u105x\u97x\u115x \u100x\u101x \u114x\u101x\u99x\u117x\u114x\u115x\u111x\u115x \u109x\u101x\u100x\u105x\u111x\u115x\u44x \u116x\u1