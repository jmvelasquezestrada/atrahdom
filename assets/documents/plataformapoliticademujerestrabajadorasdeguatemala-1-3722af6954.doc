{\pard\plain\posx1655\posy3943\absw9299\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u44x \u101x\u115x \u117x\u110x \u112x\u97x\u237x\u115x \u116x\u101x\u114x\u99x\u101x\u114x\u109x\u117x\u110x\u100x\u105x\u115x\u116x\u97x\u44x \u99x\u111x\u110x \u101x\u108x \u115x\u117x\u112x\u117x\u101x\u115x\u116x\u111x \u100x\u101x \u101x\u110x\u99x\u111x\u110x\u116x\u114x\u97x\u114x\u115x\u101x \u101x\u110x\u118x\u237x\u97x\u115x \u100x\u101x\u108x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x\u44x \u110x\u111x \u111x\u98x\u115x\u116x\u97x\u110x\u116x\u101x \u110x\u111x \u108x\u111x\u103x\u114x\u97x \u115x\u117x\u112x\u101x\u114x\u97x\u114x \u108x\u97x \u98x\u114x\u101x\u99x\u104x\u97x \u100x\u101x \u108x\u97x \u112x\u111x\u98x\u114x\u101x\u122x\u97x\u44x \u97x\u110x\u116x\u101x \u108x\u97x \u102x\u97x\u108x\u116x\u97x \u100x\u101x \u112x\u111x\u108x\u237x\u116x\u105x\u99x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u112x\u250x\u98x\u108x\u105x\u99x\u97x\u115x \u113x\u117x\u101x \u112x\u101x\u114x\u109x\u105x\u116x\u97x\u110x \u101x\u108x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x \u100x\u101x \u108x\u97x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x\u46x \u78x\u111x \u104x\u97x\u121x \u117x\u110x\u97x \u105x\u110x\u116x\u101x\u103x\u114x\u97x\u108x\u105x\u100x\u97x\u100x \u101x\u110x\u116x\u114x\u101x \u108x\u111x\u115x \u116x\u114x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u112x\u111x\u100x\u101x\u114x\u101x\u115x \u100x\u101x\u108x \u101x\u115x\u116x\u97x\u100x\u111x \u99x\u111x\u110x \u108x\u97x \u115x\u111x\u99x\u105x\u101x\u100x\u97x\u100x \u99x\u105x\u118x\u105x\u108x\u44x \u112x\u97x\u114x\u97x \u108x\u97x \u101x\u108x\u97x\u98x\u111x\u114x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u117x\u110x\u97x \u97x\u103x\u101x