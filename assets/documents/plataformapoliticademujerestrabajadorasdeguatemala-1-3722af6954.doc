{\pard\plain\posx1655\posy4512\absw9298\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f2\cf3\fs21\expnd0\expndtw0\kerning0 \u69x\u110x \u101x\u108x \u105x\u110x\u116x\u101x\u114x\u105x\u111x\u114x \u115x\u111x\u98x\u114x\u101x \u116x\u111x\u100x\u111x \u101x\u110x \u101x\u108x \u225x\u114x\u101x\u97x \u114x\u117x\u114x\u97x\u108x\u44x \u108x\u97x \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u101x\u115x \u100x\u105x\u102x\u101x\u114x\u101x\u110x\u116x\u101x\u44x \u100x\u111x\u110x\u100x\u101x \u97x\u250x\u110x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x}\par {\b0\i0\strike0\f2\cf3\fs21\expnd0\expndtw0\kerning0 \u101x\u110x \u108x\u111x\u115x \u112x\u97x\u116x\u105x\u111x\u115x \u100x\u101x \u115x\u117x\u115x \u99x\u97x\u115x\u97x\u115x\u44x \u108x\u111x\u103x\u114x\u97x\u110x \u99x\u117x\u108x\u116x\u105x\u118x\u97x\u114x \u104x\u111x\u114x\u116x\u97x\u108x\u105x\u122x\u97x\u115x \u121x \u99x\u114x\u105x\u97x\u114x \u97x\u110x\u105x\u109x\u97x\u108x\u101x\u115x \u100x\u101x \u99x\u111x\u114x\u114x\u97x\u108x\u44x \u112x\u97x\u114x\u97x \u101x\u108x}\par {\b0\i0\strike0\f2\cf3\fs21\expnd0\expndtw0\kerning0 \u99x\u111x\u110x\u115x\u117x\u109x\u111x\u44x \u112x\u101x\u114x\u111x \u109x\u117x\u99x\u104x\u97x\u115x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u111x\u110x\u101x\u115x \u110x\u111x \u108x\u111x\u103x\u114x\u97x\u110x \u115x\u111x\u98x\u114x\u101x\u118x\u105x\u118x\u105x\u114x \u99x\u111x\u110x \u101x\u108x\u108x\u111x\u44x \u116x\u101x\u110x\u105x\u101x\u110x\u100x\u111x \u113x\u117x\u101x \u109x\u105x\u103x\u114x\u97x\u114x \u97x}\par {\b0\i0\strike0\f2\cf3\fs21\expnd0\expndtw0\kerning0 \u111x\u116x\u114x\u111x\u115x \u108x\u117x\u103x\u97x\u114x\u101x\u115x \u100x\u111x\u110x\u100x\u101x \u99x\u111x\u110x\u115x\u105x\u100x\u101x\u114x\u101x\u110x \u101x\u110x\u99x\u111x\u110x\u116x\u114x\u97x\u114x \u109x\u101x\u106x\u111x\u114x\u101x\u115x \u111x\u112x\u111x\u114x\u116x\u117x\u110x\u105x\u100x\u97x\u100x\u101x\u115x \u100x\u101x \u101x\u109x\u112x\u108x\u101x\u111x\u44x \u121x \u101x\u115x\u116x\u111x \u108x\u111x}\par {\b0\i0\strike0\f2\cf3\fs21\expnd0\expndtw0\kerning0 \u104x\u97x\u99x\u101x\u110x \u108x\u97x\u115x \u99x\u105x\u117x\u100x\u97x\u100x\u101x\u115x \u111x \u97x \u108x\u97x \u99x\u97x\u112x\u105x\u116x\u97x\u108x\u44x \u111x \u98x\u105x\u101x\u110x \u97x\u108x \u101x\u120x\u116x\u114x\u97x\u110x\u106x\u101x\u114x\u111x\u46x}\par }
{\pard\plain\posx1655\posy6224\absw9299\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u76x\u111x\u115x \u109x\u111x\u100x\u101x\u108x\u111x\u115x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u111x\u115x\u44x \u98x\u117x\u115x\u99x\u97x\u110x \u103x\u101x\u110x\u101x\u114x\u97x\u114x \u117x\u110x \u100x\u101x\u115x\u103x\u97x\u115x\u116x\u101x \u101x\u110x \u108x\u97x\u115x \u101x\u109x\u112x\u114x\u101x\u115x\u97x\u115x\u44x \u115x\u111x\u98x\u114x\u101x \u108x\u97x \u99x\u97x\u114x\u103x\u97x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u108x\u97x\u115x \u112x\u108x\u97x\u110x\u105x\u108x\u108x\u97x\u115x \u100x\u101x \u112x\u97x\u103x\u111x\u115x \u100x\u101x \u108x\u111x\u115x \u101x\u109x\u112x\u108x\u101x\u97x\u100x\u111x\u115x\u44x \u112x\u111x\u114x \u108x\u111x \u113x\u117x\u101x \u101x\u110x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x \u101x\u108x \u83x\u101x\u99x\u116x\u111x\u114x \u69x\u109x\u112x\u114x\u101x\u115x\u97x\u114x\u105x\u97x\u108x\u44x \u115x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u101x\u110x\u99x\u117x\u101x\u110x\u116x\u114x\u97x \u115x\u117x\u109x\u97x\u109x\u101x\u110x\u116x\u101x \u105x\u110x\u116x\u101x\u114x\u101x\u115x\u97x\u100x\u111x \u97x \u113x\u117x\u101x \u101x\u108x \u67x\u111x\u110x\u103x\u114x\u101x\u115x\u111x \u100x\u101x \u108x\u97x \u82x\u101x\u112x\u250x\u98x\u108x\u105x\u99x\u97x \u97x\u112x\u114x\u117x\u101x\u98x\u101x \u101x\u108x \u67x\u111x\u110x\u118x\u101x\u110x\u105x\u111x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u49x\u55x\u53x \u100x\u101x \u79x\u73x\u84x}{\b0\i0\strike0\f3\cf0\fs14\expnd0\expndtw0\kerning0 \u51x }{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u109x\u105x\u115x\u109x\u111x \u113x\u117x\u101x \u115x\u101x \u114x\u101x\u102x\u105x\u101x\u114x\u101x \u97x \u108x\u97x \u99x\u114x\u101x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u117x\u110x\u97x \u110x\u117x\u