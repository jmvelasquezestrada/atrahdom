{\pard\plain\posx1655\posy3576\absw9299\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u76x\u97x\u115x \u111x\u114x\u103x\u97x\u110x\u105x\u122x\u97x\u99x\u105x\u111x\u110x\u101x\u115x \u112x\u97x\u114x\u116x\u105x\u99x\u105x\u112x\u97x\u110x\u116x\u101x\u115x \u101x\u110x \u101x\u108x }{\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u67x\u111x\u110x\u103x\u114x\u101x\u115x\u111x \u100x\u101x \u77x\u117x\u106x\u101x\u114x\u101x\u115x \u109x\u101x\u115x\u116x\u105x\u122x\u97x\u115x\u44x \u8220x\u65x\u110x\u97x\u108x\u105x\u122x\u97x\u110x\u100x\u111x \u78x\u117x\u101x\u115x\u116x\u114x\u111x}\par {\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u67x\u97x\u112x\u237x\u116x\u117x\u108x\u111x \u105x\u110x\u100x\u237x\u103x\u101x\u110x\u97x\u115x \u121x \u106x\u117x\u118x\u101x\u110x\u116x\u117x\u100x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u8221x\u44x }{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u97x\u100x\u111x \u101x\u110x \u67x\u104x\u105x\u109x\u97x\u108x\u116x\u101x\u110x\u97x\u110x\u103x\u111x\u44x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u44x \u108x\u111x\u115x \u100x\u237x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u49x\u52x\u44x\u49x\u53x \u121x \u49x\u54x \u100x\u101x \u109x\u97x\u121x\u111x \u100x\u101x\u108x \u97x\u241x\u111x \u50x\u48x\u49x\u48x\u44x \u115x\u117x\u115x\u99x\u114x\u105x\u98x\u105x\u109x\u111x\u115x \u108x\u97x \u112x\u114x\u101x\u115x\u101x\u110x\u116x\u101x }{\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u68x\u69x\u67x\u76x\u65x\u82x\u65x\u84x\u79x\u82x\u73x\u65x\u44x }{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u112x\u97x\u114x\u97x \u100x\u101x\u106x\u97x\u114x \u99x\u111x\u110x\u115x\u116x\u97x\u110x\u99x\u105x\u97x \u121x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u101x\u118x\u105x\u100x\u101x\u110x\u99x\u105x\u97x \u115x\u111x\u98x\u114x\u101x \u108x\u97x \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u108x\u97x\u98x\u111x\u114x\u97x\u108x \u113x\u117x\u101x \u97x\u102x\u114x\u111x\u110x\u116x\u97x\u109x\u111x\u115x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u101x\u110x \u108x\u97x\u115x \u114x\u97x\u109x\u97x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u100x\u101x \u108x\u111x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u115x\u101x\u99x\u116x\u111x\u114x\u101x\u115x\u58x }{\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u80x\u218x\u66x\u76x\u73x\u67x\u79x\u44x \u84x\u82x\u65x\u66x\u65x\u74x\u65x\u68x\u79x\u82x\u65x\u83x \u68x\u69x\u76x \u72x\u79x\u71x\u65x\u82x\u44x \u77x\u65x\u81x\u85x\u73x\u76x\u65x \u84x\u69x\u88x\u84x\u73x\u76x\u44x \u73x\u78x\u68x\u85x\u83x\u84x\u82x\u73x\u65x\u44x \u65x\u71x\u82x\u79x}\par {\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u69x\u88x\u79x\u80x\u79x\u82x\u84x\u65x\u67x\u73x\u79x\u78x\u44x \u69x\u78x \u76x\u65x \u69x\u67x\u79x\u78x\u79x\u77x\u73x\u65x \u73x\u78x\u68x\u69x\u80x\u69x\u78x\u68x\u73x\u69x\u78x\u84x\u69x\u44x \u74x\u85x\u86x\u69x\u78x\u84x\u85x\u68x\u44x \u68x\u69x\u76x \u67x\u65x\u77x\u80x\u79x \u121x \u84x\u82x\u65x\u66x\u65x\u74x\u65x\u68x\u79x\u82x\u65x\u83x}\par {\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u83x\u69x\u88x\u85x\u65x\u76x\u69x\u83x\u44x }{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u100x\u97x\u100x\u97x \u108x\u97x \u99x\u114x\u105x\u115x\u105x\u115x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u97x \u109x\u117x\u110x\u100x\u105x\u97x\u108x\u44x \u113x\u117x\u101x \u104x\u97x \u97x\u102x\u101x\u99x\u116x\u97x\u100x\u111x \u97x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u44x \u104x\u97x \u114x\u101x\u99x\u114x\u117x\u100x\u101x\u99x\u105x\u100x\u111x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u100x\u101x\u108x \u109x\u233x\u114x\u99x\u