{\pard\plain\posx1655\posy3847\absw9298\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u53x\u46x }{\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u69x\u110x \u108x\u111x\u115x \u99x\u97x\u115x\u111x\u115x \u100x\u101x \u108x\u97x\u115x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x \u100x\u101x \u101x\u99x\u111x\u110x\u111x\u109x\u237x\u97x \u105x\u110x\u100x\u101x\u112x\u101x\u110x\u100x\u105x\u101x\u110x\u116x\u101x\u44x }{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u115x\u101x\u99x\u116x\u111x\u114x \u113x\u117x\u101x \u115x\u101x \u104x\u97x \u105x\u110x\u99x\u114x\u101x\u109x\u101x\u110x\u116x\u97x\u100x\u111x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u100x\u101x\u98x\u105x\u100x\u111x \u97x \u108x\u97x \u102x\u97x\u108x\u116x\u97x \u100x\u101x \u99x\u114x\u101x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u102x\u117x\u101x\u110x\u116x\u101x\u115x \u100x\u101x \u101x\u109x\u112x\u108x\u101x\u111x\u44x \u112x\u111x\u114x \u108x\u111x \u113x\u117x\u101x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u118x\u97x\u110x \u105x\u110x\u99x\u117x\u114x\u115x\u105x\u111x\u110x\u97x\u110x\u100x\u111x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u101x\u110x \u101x\u108x \u116x\u114x\u97x\u98x\u97x\u106x\u111x \u105x\u110x\u102x\u111x\u114x\u109x\u97x\u108x\u59x \u99x\u111x\u109x\u111x \u118x\u101x\u110x\u100x\u101x\u100x\u111x\u114x\u97x\u115x \u100x\u101x \u99x\u97x\u116x\u97x\u108x\u111x\u103x\u111x \u44x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x \u97x \u100x\u111x\u109x\u105x\u99x\u105x\u108x\u105x\u111x\u44x \u99x\u111x\u109x\u101x\u114x\u99x\u105x\u111x\u44x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u101x\u116x\u99x\u46x\u44x \u99x\u111x\u109x\u111x \u117x\u110x \u109x\u101x\u99x\u97x\u110x\u105x\u115x\u109x\u111x \u97x\u110x\u116x\u101x \u108x\u97x \u112x\u111x\u98x\u114x\u101x\u122x\u97x \u113x\u117x\u101x \u115x\u101x \u118x\u105x\u118x\u101x \u101x\u110x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u59x \u104x\u101x\u109x\u111x\u115x \u101x\u110x\u99x\u111x\u110x\u116x\u114x\u97x\u100x\u111x \u113x\u117x\u101x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u108x\u97x \u114x\u117x\u116x\u97x \u99x\u114x\u237x\u116x\u105x\u99x\u97x \u112x\u97x\u114x\u97x \u108x\u97x \u115x\u111x\u98x\u114x\u101x\u118x\u105x\u118x\u101x\u110x\u99x\u105x\u97x \u100x\u101x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u121x \u115x\u117x\u115x \u102x\u97x\u109x\u105x\u108x\u105x\u97x\u115x\u44x \u105x\u110x\u99x\u108x\u117x\u121x\u101x \u101x\u108x \u116x\u114x\u97x\u115x\u108x\u97x\u100x\u111x \u100x\u101x\u108x \u99x\u97x\u109x\u112x\u111x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u104x\u97x\u99x\u105x\u97x \u108x\u97x \u99x\u97x\u112x\u105x\u116x\u97x\u108x \u112x\u97x\u114x\u97x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u114x \u101x\u110x \u99x\u97x\u115x\u97x \u112x\u97x\u114x\u116x\u105x\u99x\u117x\u108x\u97x\u114x\u44x \u101x\u110x \u108x\u97x\u115x \u109x\u97x\u113x\u117x\u105x\u108x\u97x\u115x\u44x \u113x\u117x\u101x \u97x\u108x \u99x\u101x\u114x\u114x\u97x\u114x\u115x\u101x \u112x\u114x\u111x\u118x\u111x\u99x\u97x\u110x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u109x\u105x\u103x\u114x\u97x\u99x\u105x\u243x\u110x \u105x\u110x\u116x\u101x\u114x\u110x\u97x \u101x \u105x\u110x\u116x\u101x\u114x\u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u44x \u121x \u101x\u108x \u97x\u117x\u109x\u101x\u110x\u116x\u111x \u100x\u101x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u101x\u110x \u101x\u108x \u116x\u114x\u97x\u98x\u97x\u106x\u111x \u115x\u101x\u120x\u117x\u97x\u108x\u44x \u100x\u111x\u110x\u100x\u101x \u101x\u120x\u105x\u115x\u116x\u101x\u110x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u109x\u97x\u121x\u111x\u114x\u101x\u115x \u101x\u120x\u112x\u108x\u111x\u116x\u97x\u99x\u105x\u111x\u110x\u101x\u115x\u46x \u76x\u97x \u118x\u105x\u111x\u108x\u101x\u110x\u99x\u105x\u97x \u101x \u105x\u110x\u115x\u101x\u103x\u117x\u114x\u105x\u100x\u97x\u100x \u113x\u117x\u101x \u115x\u101x \u118x\u105x\u118x\u101x \u101x\u110x \u101x\u108x \u112x\u97x\u237x\u115x \u121x \u112x\u111x\u114x \u108x\u97x \u102x\u97x\u108x\u116x\u97x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u111x\u112x\u111x\u114x\u116x\u117x\u110x\u105x\u100x\u97x\u100x\u101x\u115x \u100x\u101x \u101x\u109x\u112x\u108x\u101x\u111x\u44x \u114x\u101x\u115x\u117x\u108x\u116x\u97x\u110x \u101x\u110x \u101x\u108x \u100x\u101x\u115x\u112x\u108x\u97x\u122x\u97x\u109x\u105x\u101x\u110x\u116x\u111x \u100x\u101x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u113x\u117x\u101x \u118x\u97x\u110x \u100x\u101x \u117x\u110x \u108x\u117x\u103x\u97x\u114x \u97x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u111x\u116x\u114x\u111x\u44x \u100x\u101x \u117x\u110x \u101x\u109x\u112x\u108x\u101x\u111x \u97x \u111x\u116x\u114x\u111x\u44x \u121x \u115x\u111x\u109x\u101x\u116x\u105x\u233x\u110x\u100x\u111x\u115x\u101x \u97x \u99x\u111x\u110x\u100x\u105x\u99x\u105x\u111x\u110x\u101x\u115x \u99x\u97x\u100x\u97x \u109x\u225x\u115x \u100x\u101x\u112x\u108x\u111x\u114x\u97x\u98x\u108x\u101x\u115x\u44x \u113x\u117x\u101x \u108x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u108x\u108x\u101x\u118x\u97x\u110x \u104x\u97x\u115x\u116x\u97x \u112x\u101x\u114x\u100x\u101x\u114x \u108x\u97x \u118x\u105x\u100x\u97x\u46x}\par }
{\pard\plain\posx1805\posy7347\absw8995\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0 \u80x\u79x\u82x \u76x\u79x \u81x\u85x\u69x \u78x\u79x\u83x\u79x\u84x\u82x\u65x\u83x\u44x \u65x\u80x\u69x\u71x\u65x\u68x\u65x\u83x \u65x\u76x \u68x\u69x\u82x\u69x\u67x\u72x\u79x \u68x\u69x\u78x\u84x\u82x\u79x \u68x\u69x \u76x\u79x\u83x \u80x\u82x\u69x\u67x\u69x\u80x\u84x\u79x\u83x \u78x\u65x\u67x\u73x\u79x\u78x\u65x\u76x\u69x\u83x \u69x}\par {\b0\i0\strike0\f4\cf0\fs19\expnd0\expndtw0\kerning0                  \u73x\u78x\u84x\u69x\u82x\u78x\u65x\u67x\u73x\u79x\u78x\u65x\u76x\u69x\u83x \u69x\u83x\u84x\u65x\u66x\u76x\u69x\u67x\u73x\u68x\u79x\u83x\u44x \u69x\u78x\u84x\u82x\u69x \u79x\u84x\u82x\u79x\u83x\u44x}\par }
{\pard\plain\posx2005\posy8144\absw8943\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u49x\u46x \u76x\u97x \u99x\u97x\u114x\u116x\u97x \u77x\u97x\u103x\u110x\u97x \u100x\u101x \u71x\u117x\u97x\u116x\u101x\u109x\u97x\u108x\u97x\u44x \u108x\u97x \u67x\u111x\u110x\u115x\u116x\u105x\u116x\u117x\u99x\u105x\u243x\u110x \u100x\u101x \u108x\u97x \u82x\u101x\u112x\u117x\u98x\u108x\u105x\u99x\u97x\u44x \u101x\u108x \u100x\u101x\u114x\u101x\u99x\u104x\u111x \u97x \u108x\u97x \u105x\u103x\u117x\u97x\u108x\u100x\u97x\u100x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u112x\u97x\u114x\u97x \u101x\u108x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x\u46x}\par }
