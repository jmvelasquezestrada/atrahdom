{\pard\plain\posx2005\posy3053\absw8949\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u69x\u110x\u99x\u111x\u110x\u116x\u114x\u97x\u109x\u111x\u115x \u113x\u117x\u101x \u108x\u97x \u115x\u105x\u116x\u117x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u101x\u120x\u112x\u108x\u111x\u116x\u97x\u99x\u105x\u243x\u110x \u97x \u108x\u97x \u106x\u117x\u118x\u101x\u110x\u116x\u117x\u100x \u115x\u101x \u102x\u117x\u110x\u100x\u97x\u109x\u101x\u110x\u116x\u97x \u101x\u110x \u108x\u97x \u102x\u97x\u108x\u116x\u97x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u111x\u112x\u111x\u114x\u116x\u117x\u110x\u105x\u100x\u97x\u100x\u101x\u115x \u112x\u97x\u114x\u97x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x \u112x\u114x\u111x\u102x\u101x\u115x\u105x\u111x\u110x\u97x\u108x \u121x \u102x\u97x\u108x\u116x\u97x \u100x\u101x \u99x\u111x\u110x\u111x\u99x\u105x\u109x\u105x\u101x\u110x\u116x\u111x\u115x \u115x\u111x\u98x\u114x\u101x \u115x\u117x\u115x \u100x\u101x\u114x\u101x\u99x\u104x\u111x\u115x\u44x \u100x\u111x\u110x\u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u108x\u97x \u99x\u111x\u110x\u116x\u114x\u97x\u116x\u97x\u99x\u105x\u243x\u110x \u115x\u101x \u100x\u97x \u100x\u101x \u109x\u97x\u110x\u101x\u114x\u97x \u109x\u97x\u115x\u105x\u118x\u97x\u44x \u121x \u108x\u97x \u106x\u117x\u118x\u101x\u110x\u116x\u117x\u100x \u115x\u101x \u118x\u101x \u111x\u98x\u108x\u105x\u103x\u97x\u100x\u97x \u97x \u97x\u99x\u101x\u112x\u116x\u97x\u114x \u108x\u97x\u115x \u99x\u111x\u110x\u100x\u105x\u99x\u105x\u111x\u110x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u105x\u109x\u112x\u111x\u115x\u105x\u116x\u105x\u118x\u97x\u115x \u121x \u118x\u105x\u111x\u108x\u97x\u116x\u111x\u114x\u105x\u97x\u115x \u112x\u111x\u114x \u108x\u97x \u110x\u101x\u99x\u101x\u115x\u105x\u100x\u97x\u100x \u100x\u101x \u117x\u110x \u115x\u97x\u108x\u97x\u114x\u105x\u111x \u121x \u108x