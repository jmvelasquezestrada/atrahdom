{\pard\plain\posx2005\posy3053\absw8948\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0 \u53x\u46x \u69x\u108x \u67x\u111x\u110x\u115x\u101x\u110x\u115x\u111x \u100x\u101x \u81x\u117x\u105x\u116x\u111x\u44x \u101x\u109x\u105x\u116x\u105x\u100x\u111x \u100x\u117x\u114x\u97x\u110x\u116x\u101x \u108x\u97x \u88x \u67x\u111x\u110x\u102x\u101x\u114x\u101x\u110x\u99x\u105x\u97x \u82x\u101x\u103x\u105x\u111x\u110x\u97x\u108x \u100x\u101x \u108x\u97x \u77x\u117x\u106x\u101x\u114x \u100x\u101x \u65x\u109x\u233x\u114x\u105x\u99x\u97x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u76x\u97x\u116x\u105x\u110x\u97x \u121x \u101x\u108x \u67x\u97x\u114x\u105x\u98x\u101x \u101x\u110x \u69x\u99x\u117x\u97x\u100x\u111x\u114x \u100x\u101x\u108x \u54x \u97x\u108x \u57x \u100x\u101x \u97x\u103x\u111x\u115x\u116x\u111x \u100x\u101x\u108x \u50x\u48x\u48x\u55x\u44x \u113x\u117x\u101x \u100x\u101x\u110x\u117x\u110x\u99x\u105x\u97x \u108x\u97x \u100x\u105x\u118x\u105x\u115x\u105x\u243x\u110x \u115x\u101x\u120x\u117x\u97x\u108x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u100x\u101x\u108x \u116x\u114x\u97x\u98x\u97x\u106x\u111x \u99x\u111x\u109x\u111x \u102x\u97x\u99x\u116x\u111x\u114x \u101x\u115x\u116x\u114x\u117x\u99x\u116x\u117x\u114x\u97x\u108x \u100x\u101x \u108x\u97x\u115x \u100x\u101x\u115x\u105x\u103x\u117x\u97x\u108x\u100x\u97x\u100x\u101x\u115x \u121x \u108x\u97x\u115x \u105x\u110x\u106x\u117x\u115x\u116x\u105x\u99x\u105x\u97x\u115x \u121x \u113x\u117x\u101x \u114x\u101x\u99x\u111x\u110x\u111x\u99x\u101x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u115x\u105x\u103x\u110x\u105x\u102x\u105x\u99x\u97x\u116x\u105x\u118x\u97x \u99x\u111x\u110x\u116x\u114x\u105x\u98x\u117x\u99x\u105x\u243x\u110x \u100x\u101x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u101x\u110x \u115x\u117x \u100x\u105x\u118x\u101x\u114x\u115x\u105x\u100x\u97x\u100x\u44x \u97x \u108x\u97x \u101x\u99x\u111x\u110x\u111x\u109x\u237x\u97x\u44x \u97x\u108x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u101x\u115x\u116x\u114x\u97x\u116x\u101x\u103x\u105x\u97x\u115x \u112x\u97x\u114x\u97x \u101x\u110x\u102x\u114x\u101x\u110x\u116x\u97x\u114x \u108x\u97x \u112x\u111x\u98x\u114x\u101x\u122x\u97x\u44x \u108x\u97x \u112x\u114x\u101x\u115x\u101x\u114x\u118x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u99x\u111x\u110x\u111x\u99x\u105x\u109x\u105x\u101x\u110x\u116x\u111x\u115x \u121x \u112x\u114x\u225x\u99x\u116x\u105x\u99x\u97x\u115x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u102x\u117x\u110x\u100x\u97x\u109x\u101x\u110x\u116x\u97x\u108x\u101x\u115x \u112x\u97x\u114x\u97x \u108x\u97x \u118x\u105x\u100x\u97x\u44x \u101x\u115x\u112x\u101x\u99x\u105x\u97x\u108x\u109x\u101x\u110x\u116x\u101x \u112x\u97x\u114x\u97x \u108x\u97x \u115x\u101x\u103x\u117x\u114x\u105x\u100x\u97x\u100x \u121x \u108x\u97x \u115x\u111x\u98x\u101x\u114x\u97x\u110x\u237x\u97x \u97x\u108x\u105x\u109x\u101x\u110x\u116x\u97x\u114x\u105x\u97x \u121x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u108x\u97x \u115x\u97x\u108x\u117x\u100x\u44x \u101x\u110x\u102x\u97x\u116x\u105x\u122x\u97x\u110x\u100x\u111x \u101x\u110x \u108x\u97x \u105x\u109x\u112x\u111x\u114x\u116x\u97x\u110x\u99x\u105x\u97x \u100x\u101x\u108x \u118x\u97x\u108x\u111x\u114x \u101x\u99x\u111x\u110x\u243x\u109x\u105x\u99x\u111x \u121x \u115x\u111x\u99x\u105x\u97x\u108x \u100x\u101x\u108x \u116x\u114x\u97x\u98x\u97x\u106x\u111x \u97x\u103x\u114x\u237x\u99x\u111x\u108x\u97x \u121x}\par {\b0\i0\strike0\f3\cf0\fs19\expnd0\expndtw0\kerning0    \u100x\u101x \u115x\u117x\u98x\u115x\u105x\u115x\u116x\u101x\u110x\u99x\u105x\u97x \u113x\u117x\u101x \u114x\u101x\u97x\u108x\u105x\u122x\u97x\u110x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u114x\u117x\u114x\u97x\u108x\u101x\u115x \u121x \u99x\u97x\u109x\u1