{\pard\plain\posx1655\posy1664\absw9298\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u97x\u108x\u116x\u97x\u109x\u101x\u110x\u116x\u101x \u108x\u97x\u109x\u101x\u110x\u116x\u97x\u98x\u108x\u101x\u115x\u44x \u112x\u111x\u114x\u113x\u117x\u101x \u101x\u110x \u101x\u115x\u116x\u111x\u115x \u115x\u101x \u101x\u118x\u105x\u100x\u101x\u110x\u99x\u105x\u97x\u110x \u110x\u111x \u115x\u111x\u108x\u111x \u100x\u101x\u102x\u105x\u99x\u105x\u101x\u110x\u99x\u105x\u97x\u115x \u112x\u111x\u114x \u108x\u97x \u102x\u97x\u108x\u116x\u97x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u118x\u111x\u108x\u117x\u110x\u116x\u97x\u100x\u101x\u115x \u121x \u99x\u97x\u112x\u97x\u99x\u105x\u100x\u97x\u100x\u101x\u115x \u100x\u101x \u101x\u106x\u101x\u114x\u99x\u101x\u114x \u117x\u110x \u112x\u117x\u101x\u115x\u116x\u111x \u100x\u101x \u116x\u114x\u97x\u98x\u97x\u106x\u111x\u44x \u121x\u97x \u113x\u117x\u101x \u101x\u115x \u112x\u114x\u111x\u100x\u117x\u99x\u116x\u111x\u44x \u100x\u101x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u99x\u111x\u110x\u116x\u114x\u97x\u116x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u112x\u101x\u114x\u115x\u111x\u110x\u97x\u108x\u44x \u113x\u117x\u101x \u110x\u111x \u115x\u97x\u98x\u101x \u110x\u105x \u101x\u110x\u116x\u105x\u101x\u110x\u100x\u101x \u113x\u117x\u101x \u101x\u115x \u108x\u111x \u113x\u117x\u101x \u116x\u105x\u101x\u110x\u101x \u113x\u117x\u101x \u104x\u97x\u99x\u101x\u114x \u101x\u110x \u115x\u117x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u112x\u117x\u101x\u115x\u116x\u111x \u100x\u101x \u116x\u114x\u97x\u98x\u97x\u106x\u111x\u44x \u101x\u108x \u99x\u117x\u97x\u108x \u109x\u117x\u99x\u104x\u97x\u115x \u118x\u101x\u99x\u101x\u115x \u108x\u111x\u115x \u104x\u97x\u110x \u111x\u98x\u116x\u101x\u110x\u105x\u100x\u111x \u112x\u111x\u114x \u109x\u101x\u100x\u105x\u111x \u100x\u101x \u108x\u97x\u115x \u105x\u110x\u102x\u108x\u117x