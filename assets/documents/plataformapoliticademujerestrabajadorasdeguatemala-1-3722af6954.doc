u115x\u44x \u104x\u97x\u99x\u105x\u233x\u110x\u100x\u111x\u108x\u101x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u117x\u110x\u97x \u115x\u111x\u98x\u114x\u101x \u99x\u97x\u114x\u103x\u97x \u100x\u101x \u116x\u114x\u97x\u98x\u97x\u106x\u111x\u44x \u101x\u115x\u116x\u111x \u108x\u97x\u115x \u109x\u117x\u106x\u101x\u114x\u101x\u115x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x \u100x\u101x \u116x\u111x\u100x\u97x\u115x \u108x\u97x\u115x \u114x\u97x\u109x\u97x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u108x\u97x \u101x\u99x\u111x\u110x\u111x\u109x\u237x\u97x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u77x\u117x\u99x\u104x\u97x \u115x\u101x \u104x\u97x\u98x\u108x\u97x \u115x\u111x\u98x\u114x\u101x \u108x\u97x \u102x\u108x\u101x\u120x\u105x\u98x\u105x\u108x\u105x\u100x\u97x\u100x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u44x \u115x\u105x\u101x\u110x\u100x\u111x \u101x\u115x\u116x\u111x \u117x\u110x \u112x\u117x\u110x\u116x\u111x \u101x\u110x \u99x\u111x\u110x\u116x\u114x\u97x \u100x\u101x \u108x\u111x\u115x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u101x\u115x \u121x \u116x\u114x\u97x\u98x\u97x\u106x\u97x\u100x\u111x\u114x\u97x\u115x\u44x \u113x\u117x\u101x\u114x\u105x\u233x\u110x\u100x\u111x\u115x\u101x \u101x\u115x\u116x\u97x\u98x\u108x\u101x\u99x\u101x\u114x \u113x\u117x\u101x \u112x\u97x\u114x\u97x \u108x\u97x\u115x \u101x\u109x\u112x\u114x\u101x\u115x\u97x\u115x \u100x\u101x\u98x\u101x\u110x \u100x\u101x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u99x\u117x\u109x\u112x\u108x\u105x\u114x \u99x\u111x\u110x \u108x\u97x\u115x \u110x\u111x\u114x\u109x\u97x\u115x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x \u101x \u105x\u110x\u116x\u101x\u114x\u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x \u99x\u111x\u109x\u111x \u11