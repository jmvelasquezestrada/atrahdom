ning0 \u105x\u110x\u115x\u116x\u105x\u116x\u117x\u99x\u105x\u111x\u110x\u101x\u115x \u115x\u111x\u99x\u105x\u97x\u108x\u101x\u115x \u101x \u105x\u110x\u116x\u101x\u114x\u110x\u97x\u99x\u105x\u111x\u110x\u97x\u108x\u101x\u115x\u44x \u113x\u117x\u101x \u116x\u114x\u97x\u116x\u97x\u109x\u111x\u115x \u100x\u101x \u114x\u101x\u115x\u99x\u97x\u116x\u97x\u114x \u121x \u97x\u112x\u111x\u121x\u97x\u114x \u97x \u115x\u117x \u100x\u101x\u115x\u97x\u114x\u114x\u111x\u108x\u108x\u111x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u104x\u117x\u109x\u97x\u110x\u111x\u46x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u80x\u111x\u114x \u108x\u111x \u113x\u117x\u101x \u110x\u111x\u115x\u111x\u116x\u114x\u97x\u115x \u99x\u111x\u110x\u115x\u105x\u100x\u101x\u114x\u97x\u109x\u111x\u115x \u113x\u117x\u101x \u101x\u115x\u116x\u101x \u115x\u101x\u99x\u116x\u111x\u114x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u44x \u101x\u115x \u97x\u108x\u116x\u97x\u109x\u101x\u110x\u116x\u101x \u115x\u117x\u106x\u101x\u116x\u111x \u97x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u118x\u105x\u111x\u108x\u97x\u116x\u111x\u114x\u105x\u97x \u100x\u101x \u115x\u117x\u115x \u100x\u101x\u114x\u101x\u99x\u104x\u111x\u115x \u104x\u117x\u109x\u97x\u110x\u111x\u115x \u121x \u108x\u97x\u98x\u111x\u114x\u97x\u108x\u101x\u115x\u44x \u97x \u112x\u101x\u115x\u97x\u114x \u113x\u117x\u101x \u97x\u99x\u116x\u117x\u97x\u108x\u109x\u101x\u110x\u116x\u101x \u108x\u97x \u67x\u111x\u110x\u102x\u101x\u114x\u101x\u110x\u99x\u105x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u100x\u101x \u79x\u73x\u84x}{\b0\i0\strike0\f3\cf0\fs14\expnd0\expndtw0\kerning0 \u56x }{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u101x\u115x\u116x\u97x\u98x\u108x\u101x\u99x\u101x \u108x\u97x \u114x\u101x\u99x\u111x\u109x\u101x\u110x\u100x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u110x\u111x \u99x\u111x\u110x\u116x\u114x\u97x\u116x\u97x\u99x\u105x\u243x\u110x \u100x\u101x \u109