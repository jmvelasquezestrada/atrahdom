{\pard\plain\posx1655\posy7079\absw9298\absh0\dxfrtext0\dfrmtxtx0\dfrmtxty0\nosnaplinegrid{\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u72x\u97x\u121x \u117x\u110x \u101x\u108x\u101x\u118x\u97x\u100x\u111x \u99x\u111x\u115x\u116x\u111x \u101x\u110x \u108x\u111x\u115x \u112x\u114x\u111x\u100x\u117x\u99x\u116x\u111x\u115x \u97x\u108x\u105x\u109x\u101x\u110x\u116x\u105x\u99x\u105x\u111x\u115x\u44x \u112x\u97x\u114x\u97x \u112x\u111x\u100x\u101x\u114x \u112x\u111x\u115x\u101x\u101x\u114x \u117x\u110x\u97x \u97x\u108x\u105x\u109x\u101x\u110x\u116x\u97x\u99x\u105x\u243x\u110x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u97x\u100x\u101x\u99x\u117x\u97x\u100x\u97x\u44x \u113x\u117x\u101x \u105x\u110x\u99x\u117x\u114x\u114x\u97x \u101x\u110x \u108x\u111x\u115x \u116x\u114x\u101x\u115x \u103x\u114x\u117x\u112x\u111x\u115x \u98x\u225x\u115x\u105x\u99x\u111x\u115x \u100x\u101x \u108x\u97x \u97x\u108x\u105x\u109x\u101x\u110x\u116x\u97x\u99x\u105x\u243x\u110x\u44x \u108x\u111x \u113x\u117x\u101x \u101x\u115x \u110x\u101x\u99x\u101x\u115x\u97x\u114x\u105x\u111x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u112x\u97x\u114x\u97x \u101x\u108x \u99x\u117x\u101x\u114x\u112x\u111x \u104x\u117x\u109x\u97x\u110x\u111x\u44x \u116x\u101x\u110x\u101x\u114x \u115x\u97x\u108x\u117x\u100x \u101x\u110x \u108x\u97x \u109x\u101x\u110x\u116x\u101x \u121x \u101x\u108x \u99x\u117x\u101x\u114x\u112x\u111x\u44x \u101x\u108x\u108x\u111x \u115x\u105x\u103x\u110x\u105x\u102x\u105x\u99x\u97x \u113x\u117x\u101x \u108x\u97x \u110x\u105x\u241x\u101x\u122x \u121x \u108x\u97x}\par {\b0\i0\strike0\f3\cf0\fs21\expnd0\expndtw0\kerning0 \u106x\u117x\u118x\u101x\u110x\u116x\u117x\u100x \u110x\u111x \u101x\u115x\u116x\u225x\u110x \u115x\u105x\u101x\u110x\u100x\u111x \u98x\u105x\u101x\u110x \u97x\u108x\u105x\u109x\u101x\u110x\u116x\u97x\u100x\u97x\u115x\u44x \u101x\u110x \u101x\u108x \u56x\u48x\u37x \u100x\u101x \u108x\u97x \u112x\u111x\u98x\u108x\u97x\u99x\u105x\u243x\u110x \u112